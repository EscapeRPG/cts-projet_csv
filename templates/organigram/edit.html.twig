{% extends 'base.html.twig' %}

{% block title %}Editer organigrammes{% endblock %}

{% block body %}
    <div class="form-wrapper">
        {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
            {{ form_row(form.pdf) }}
            <button type="submit">Uploader</button>
        {{ form_end(form) }}

        {% if hasPdf %}
            <div class="configure-pdf">
                <a class="btn-link" href="{{ path('app_organigram_configure') }}">Configurer</a>
            </div>
        {% endif %}
    </div>
{% endblock %}

