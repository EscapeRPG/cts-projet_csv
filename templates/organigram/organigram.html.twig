{% extends 'base.html.twig' %}

{% block title %}Organigrammes structurels{% endblock %}

{% block body %}
    {% set route = app.request.attributes.get('_route') %}

    <div class="suivi-container organigram-container" data-disable-mobile-filters-drawer="1">
        <div class="sidenav">
            <div class="onglets">
                {% if is_granted('ROLE_ORGANIGRAM_STRUCT_VIEW') %}
                    <a href="{{ path('app_organigram') }}"
                       class="{{ route == 'app_organigram' ? 'active' : '' }}"
                    >
                        Exploitations
                    </a>
                {% endif %}

                {% if is_granted('ROLE_ORGANIGRAM_IMMO_VIEW') %}
                    <a href="{{ path('app_organigram_immobilier') }}"
                       class="{{ route == 'app_organigram_immobilier' ? 'active' : '' }}"
                    >
                        Immobilier
                    </a>
                {% endif %}

                {% if is_granted('ROLE_ORGANIGRAM_HIERARCHY_VIEW') %}
                    <a href="{{ path('app_organigram_hierarchique') }}"
                       class="{{ route == 'app_organigram_hierarchique' ? 'active' : '' }}"
                    >
                        Hiérarchie
                    </a>
                {% endif %}
            </div>

            {% if is_granted('ROLE_ADMIN') %}
                <div class="organigram-admin-actions">
                    <a href="{{ path('app_organigram_edit') }}" class="btn-link edit">Éditer</a>
                </div>
            {% endif %}
        </div>

        <div class="organigram-view"
             data-organigram-view="1"
             data-pdf-url="{{ pdfUrl ?? '' }}"
             data-page="{{ page ?? '' }}"
             data-pdf-worker-url="{{ asset('vendor/pdfjs-dist/build/pdf.worker.mjs.js') }}">
            {% if pdfUrl is empty %}
                <div class="organigram-empty">
                    <p>Aucun PDF configuré.</p>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_organigram_edit') }}" class="btn-link">Configurer</a>
                    {% endif %}
                </div>
            {% elseif page is empty %}
                <div class="organigram-empty">
                    <p>Aucun organigramme hiérarchique paramétré à l'heure actuelle.</p>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_organigram_configure') }}" class="btn-link">Configurer</a>
                    {% endif %}
                </div>
            {% else %}
                <canvas class="organigram-canvas" data-organigram-canvas="1"></canvas>
            {% endif %}
        </div>
    </div>
{% endblock %}
