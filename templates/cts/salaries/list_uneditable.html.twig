{% extends 'base.html.twig' %}

{% block title %}Liste des salariés{% endblock %}

{% block body %}
    <div class="search-list">
        <label for="cts-salaries-search-uneditable">Recherche :</label>
        <input id="cts-salaries-search-uneditable"
               type="search"
               autocomplete="off"
               placeholder="Nom, prénom, agr..."
               value="{{ app.request.query.get('q') }}"
               data-list-search-input="1"
               data-list-search-partial-url="{{ path('app_salaries_list_uneditable_partial') }}"
               data-list-search-push-url="{{ path('app_salaries_list_uneditable') }}"
               data-list-search-results="#cts-salaries-uneditable-results">
        {% set includeActive = app.request.query.get('active') != '0' %}
        {% set includeInactive = app.request.query.get('inactive') == '1' %}
        <label for="cts-salaries-active-only-uneditable" style="margin-left: 12px;">Actifs</label>
        <input id="cts-salaries-active-only-uneditable"
               type="checkbox"
               name="active"
               value="1"
               data-list-search-param="1"
            {{ includeActive ? 'checked' : '' }}>
        <label for="cts-salaries-inactive-only-uneditable" style="margin-left: 8px;">Inactifs</label>
        <input id="cts-salaries-inactive-only-uneditable"
               type="checkbox"
               name="inactive"
               value="1"
               data-list-search-param="1"
            {{ includeInactive ? 'checked' : '' }}>
    </div>

    <div class="container">
        <div id="cts-salaries-uneditable-results" data-list-results-container="1">
            {{ include('cts/salaries/_list_results_uneditable.html.twig') }}
        </div>
    </div>

    {% set errorsMessages = app.flashes('error') %}
    {% if errorsMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h3>Erreurs détectées</h3>
                <ul>
                    {% for error in errorsMessages %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% set successMessages = app.flashes('success') %}
    {% if successMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal success-modal" data-modals-target="modal">
                <h2>Succès</h2>

                {% for message in successMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    {% set warningMessages = app.flashes('warning') %}
    {% if warningMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h2>Attention</h2>

                {% for message in warningMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    <div class="edit-print">
        {% if is_granted('ROLE_LIST_SALARIES_ADD') %}
            <a href="{{ path('app_salaries_add') }}" class="btn-link add">Ajouter</a>
        {% endif %}

        {% if is_granted('ROLE_LIST_SALARIES_EDIT') %}
            <a href="{{ path('app_salaries_list') }}" class="btn-link">Modifier</a>
        {% endif %}

        <a class="btn-link"
           href="{{ path('app_salaries_list_uneditable_print') }}"
           data-print-keep-filters="1"
           data-print-base-href="{{ path('app_salaries_list_uneditable_print') }}"
           target="_blank"
           rel="noopener">Imprimer</a>
    </div>
{% endblock %}
