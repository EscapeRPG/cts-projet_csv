{% extends 'base.html.twig' %}

{% block title %}Liste des salariés{% endblock %}

{% block body %}
    <div class="list-container">
        {% if pagination is defined %}
            {% set startItem = pagination.total_items > 0 ? ((pagination.page - 1) * pagination.per_page) + 1 : 0 %}
            {% set endItem = (pagination.page * pagination.per_page) > pagination.total_items ? pagination.total_items : (pagination.page * pagination.per_page) %}
        {% endif %}

        <div class="search-list">
            <div class="form-row">
                <label for="cts-salaries-search">Recherche :</label>
                <input id="cts-salaries-search"
                       type="search"
                       autocomplete="off"
                       placeholder="Nom, prénom, agr..."
                       value="{{ app.request.query.get('q') }}"
                       data-list-search-input="1"
                       data-list-search-partial-url="{{ path('app_salaries_list_partial') }}"
                       data-list-search-push-url="{{ path('app_salaries_list') }}"
                       data-list-search-results="#cts-salaries-results">
            </div>

            <div class="form-row">
                {% set includeActive = app.request.query.get('active') != '0' %}
                {% set includeInactive = app.request.query.get('inactive') == '1' %}
                <label for="cts-salaries-active-only" style="margin-left: 12px;">Actifs</label>
                <input id="cts-salaries-active-only"
                       type="checkbox"
                       name="active"
                       value="1"
                       data-list-search-param="1"
                    {{ includeActive ? 'checked' : '' }}>
            </div>

            <div class="form-row">
                <label for="cts-salaries-inactive-only" style="margin-left: 8px;">Inactifs</label>
                <input id="cts-salaries-inactive-only"
                       type="checkbox"
                       name="inactive"
                       value="1"
                       data-list-search-param="1"
                    {{ includeInactive ? 'checked' : '' }}>
            </div>

            <small data-list-search-blocked-message hidden>Veuillez enregistrer vos modifications pour effectuer une
                recherche.</small>
        </div>

        <div id="cts-salaries-results" class="table-wrapper" data-list-results-container="1">
            {{ include('cts/salaries/_list_results.html.twig') }}
        </div>

        {% if pagination is defined and pagination.total_pages > 1 %}
            <div class="pagination-nav" aria-label="Pagination des salariés">
                <a href="{{ path('app_salaries_list', app.request.query.all|merge({'page': 1})) }}" {{ pagination.has_previous ? '' : 'class="disabled"' }}>❮❮</a>
                <a href="{{ path('app_salaries_list', app.request.query.all|merge({'page': pagination.previous_page})) }}" {{ pagination.has_previous ? '' : 'class="disabled"' }}>❮</a>
                <span>Page {{ pagination.page }} / {{ pagination.total_pages }} ({{ pagination.total_items }} salariés)</span>
                <a href="{{ path('app_salaries_list', app.request.query.all|merge({'page': pagination.next_page})) }}" {{ pagination.has_next ? '' : 'class="disabled"' }}>❯</a>
                <a href="{{ path('app_salaries_list', app.request.query.all|merge({'page': pagination.total_pages})) }}" {{ pagination.has_next ? '' : 'class="disabled"' }}>❯❯</a>
            </div>
        {% endif %}

        <div class="filters-print-actions">
            <a class="btn-link"
               href="{{ path('app_salaries_list_uneditable_print') }}"
               data-print-keep-filters="1"
               data-print-base-href="{{ path('app_salaries_list_uneditable_print') }}"
               target="_blank"
               rel="noopener">Imprimer</a>
        </div>
    </div>

    {% set errorsMessages = app.flashes('error') %}
    {% if errorsMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h3>Erreurs détectées</h3>
                <ul>
                    {% for error in errorsMessages %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% set successMessages = app.flashes('success') %}
    {% if successMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal success-modal" data-modals-target="modal">
                <h2>Succès</h2>

                {% for message in successMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    {% set warningMessages = app.flashes('warning') %}
    {% if warningMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h2>Attention</h2>

                {% for message in warningMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}
{% endblock %}
