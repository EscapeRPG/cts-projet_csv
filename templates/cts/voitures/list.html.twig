{% extends 'base.html.twig' %}

{% block title %}Liste des voitures{% endblock %}

{% block body %}
    <div class="list-container">
        {% if pagination is defined and pagination is not null %}
            {% set startItem = pagination.total_items > 0 ? ((pagination.page - 1) * pagination.per_page) + 1 : 0 %}
            {% set endItem = (pagination.page * pagination.per_page) > pagination.total_items ? pagination.total_items : (pagination.page * pagination.per_page) %}
        {% endif %}

        <div class="search-list">
            <div class="form-row">
                <label for="cts-voitures-search">Recherche :</label>
                <input id="cts-voitures-search"
                       type="search"
                       autocomplete="off"
                       placeholder="Immatriculation..."
                       value="{{ app.request.query.get('q') }}"
                       data-list-search-input="1"
                       data-list-search-partial-url="{{ path('app_voitures_list_partial') }}"
                       data-list-search-push-url="{{ path('app_voitures_list') }}"
                       data-list-search-results="#cts-voitures-results">
            </div>

            <div class="form-row">
                {% set includeActive = app.request.query.get('active') != '0' %}
                {% set includeInactive = app.request.query.get('inactive') == '1' %}
                <label for="cts-voitures-active-only" style="margin-left: 12px;">Actives</label>
                <input id="cts-voitures-active-only"
                       type="checkbox"
                       name="active"
                       value="1"
                       data-list-search-param="1"
                    {{ includeActive ? 'checked' : '' }}>
            </div>

            <div class="form-row">
                <label for="cts-voitures-inactive-only" style="margin-left: 8px;">Inactives</label>
                <input id="cts-voitures-inactive-only"
                       type="checkbox"
                       name="inactive"
                       value="1"
                       data-list-search-param="1"
                    {{ includeInactive ? 'checked' : '' }}>
            </div>

            <small data-list-search-blocked-message hidden>Veuillez enregistrer vos modifications pour effectuer une
                recherche.</small>
        </div>

        <div id="cts-voitures-results" class="table-wrapper" data-list-results-container="1">
            {{ include('cts/voitures/_list_results.html.twig') }}
        </div>

        <div class="filters-print-actions">
            {% if is_granted('ROLE_LIST_VOITURES_EDIT') %}
                <button type="submit"
                        form="voitures-bulk-form"
                        disabled
                        data-row-save-button="1"
                        data-bulk-save-button="1">Enregistrer</button>
            {% endif %}
            <a class="btn-link"
               href="{{ path('app_voitures_list_uneditable_print') }}"
               data-print-keep-filters="1"
               data-print-base-href="{{ path('app_voitures_list_uneditable_print') }}"
               target="_blank"
               rel="noopener">Imprimer</a>
        </div>
    </div>

    {% set errorsMessages = app.flashes('error') %}
    {% if errorsMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h3>Erreurs détectées</h3>
                <ul>
                    {% for error in errorsMessages %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% set successMessages = app.flashes('success') %}
    {% if successMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal success-modal" data-modals-target="modal">
                <h2>Succès</h2>

                {% for message in successMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    {% set warningMessages = app.flashes('warning') %}
    {% if warningMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h2>Attention</h2>

                {% for message in warningMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}
{% endblock %}
