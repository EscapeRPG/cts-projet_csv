{% extends 'base.html.twig' %}

{% block title %}Liste des sociétés{% endblock %}

{% block body %}
    <div class="search-list">
        <label for="cts-societes-search-uneditable">Recherche :</label>
        <input id="cts-societes-search-uneditable"
               type="search"
               autocomplete="off"
               placeholder="Nom..."
               value="{{ app.request.query.get('q') }}"
               data-list-search-input="1"
               data-list-search-partial-url="{{ path('app_societes_list_uneditable_partial') }}"
               data-list-search-push-url="{{ path('app_societes_list_uneditable') }}"
               data-list-search-results="#cts-societes-uneditable-results">
    </div>

    <div class="container">
        <div id="cts-societes-uneditable-results" data-list-results-container="1">
            {{ include('cts/societes/_list_results_uneditable.html.twig') }}
        </div>
    </div>

    {% set errorsMessages = app.flashes('error') %}
    {% if errorsMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h3>Erreurs détectées</h3>
                <ul>
                    {% for error in errorsMessages %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% set successMessages = app.flashes('success') %}
    {% if successMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal success-modal" data-modals-target="modal">
                <h2>Succès</h2>

                {% for message in successMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    {% set warningMessages = app.flashes('warning') %}
    {% if warningMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h2>Attention</h2>

                {% for message in warningMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    <div class="edit-print">
        <a href="{{ path('app_societes_list') }}" class="btn-link">Modifier</a>

        <a class="btn-link"
           href="{{ path('app_societes_list_print') }}"
           data-print-keep-filters="1"
           data-print-base-href="{{ path('app_societes_list_print') }}"
           target="_blank"
           rel="noopener">Imprimer</a>
    </div>
{% endblock %}
