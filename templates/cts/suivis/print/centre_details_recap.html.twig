{% extends 'cts/suivis/print/_base.html.twig' %}

{% set printTitle = 'Suivi details centre (recap)' %}
{% set printOrientation = 'landscape' %}
{% set autoPrint = true %}
{% set printVariant = 'centre-details-recap' %}

{% block content %}
    {% if selectedCentreCount == 0 %}
        <div class="centre-detail-alert">
            <p>Veuillez selectionner un centre pour consulter les details.</p>
        </div>
    {% elseif selectedCentreCount > 1 %}
        <div class="centre-detail-alert">
            <p>Veuillez selectionner un seul centre pour consulter les details.</p>
        </div>
    {% elseif centreActivity is null %}
        <div class="centre-detail-alert">
            <p>Aucune donnee disponible pour ce centre sur la periode selectionnee.</p>
        </div>
    {% else %}
        {% set activityTotals = centreActivity.totaux %}

        <div class="print-centre-recap">
            <div class="pro-stats-container">
                <div class="pro-stats-panel">
                    <div class="summary">
                        <div class="ca-summary">
                            <span class="panel-tools-title">CA {{ referenceYear }}</span>
                            <strong>{{ summary.ca_now|number_format(2, ',', ' ') }} €</strong>

                            <div class="previous">
                                <div class="row">
                                    <strong>{{ referenceYear - 1 }}</strong>
                                    {{ summary.ca_n1|number_format(2, ',', ' ') }} €
                                    <div class="{{ summary.per_ca_n1 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ca_n1|number_format(2, ',', ' ') }}%</div>
                                </div>

                                <div class="row">
                                    <strong>{{ referenceYear - 2 }}</strong>
                                    {{ summary.ca_n2|number_format(2, ',', ' ') }} €
                                    <div class="{{ summary.per_ca_n2 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ca_n2|number_format(2, ',', ' ') }}%</div>
                                </div>
                            </div>
                        </div>

                        <div class="ca-summary">
                            <span class="panel-tools-title">Controles {{ referenceYear }}</span>
                            <strong>{{ summary.vol_now|number_format(0, ',', ' ') }}</strong>

                            <div class="previous">
                                <div class="row">
                                    <strong>{{ referenceYear - 1 }}</strong>
                                    {{ summary.vol_n1|number_format(0, ',', ' ') }}
                                    <div class="{{ summary.per_ctrl_n1 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ctrl_n1|number_format(2, ',', ' ') }}%</div>
                                </div>

                                <div class="row">
                                    <strong>{{ referenceYear - 2 }}</strong>
                                    {{ summary.vol_n2|number_format(0, ',', ' ') }}
                                    <div class="{{ summary.per_ctrl_n2 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ctrl_n2|number_format(2, ',', ' ') }}%</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="summary">
                        <div class="pro-part-panel">
                            {% set years = [
                                {'label': (referenceYear - 2), 'ca_part': splitSummary.ca_part_n2, 'ca_pro': splitSummary.ca_pro_n2, 'vol_part': splitSummary.vol_part_n2, 'vol_pro': splitSummary.vol_pro_n2},
                                {'label': (referenceYear - 1), 'ca_part': splitSummary.ca_part_n1, 'ca_pro': splitSummary.ca_pro_n1, 'vol_part': splitSummary.vol_part_n1, 'vol_pro': splitSummary.vol_pro_n1},
                                {'label': referenceYear,       'ca_part': splitSummary.ca_part_now, 'ca_pro': splitSummary.ca_pro_now, 'vol_part': splitSummary.vol_part_now, 'vol_pro': splitSummary.vol_pro_now},
                            ] %}

                            {% set max_ca_total = max(
                                splitSummary.ca_part_n2 + splitSummary.ca_pro_n2,
                                splitSummary.ca_part_n1 + splitSummary.ca_pro_n1,
                                splitSummary.ca_part_now + splitSummary.ca_pro_now
                            ) %}
                            {% set max_vol_total = max(
                                splitSummary.vol_part_n2 + splitSummary.vol_pro_n2,
                                splitSummary.vol_part_n1 + splitSummary.vol_pro_n1,
                                splitSummary.vol_part_now + splitSummary.vol_pro_now
                            ) %}

                            <div class="panel-tools">
                                <span class="panel-tools-title">CA</span>
                                <div class="legende">
                                    <div class="part"></div>
                                    Part
                                    <div class="pro"></div>
                                    Pros
                                </div>
                            </div>

                            <div class="ca-pro-part">
                                {% for y in years %}
                                    {% set percent_ca_part = max_ca_total > 0 ? (y.ca_part * 100 / max_ca_total) : 0 %}
                                    {% set percent_ca_pro = max_ca_total > 0 ? (y.ca_pro * 100 / max_ca_total) : 0 %}
                                    {% set percent_vol_part = max_vol_total > 0 ? (y.vol_part * 100 / max_vol_total) : 0 %}
                                    {% set percent_vol_pro = max_vol_total > 0 ? (y.vol_pro * 100 / max_vol_total) : 0 %}

                                    <div class="col-pro-part">
                                        <div class="metric metric-top">
                                            <span class="col-part" style="height: {{ percent_ca_part }}%">
                                                <span class="bar-label">{{ (y.ca_part / 1000)|number_format(2, ',', ' ') }} K</span>
                                            </span>
                                            <span class="col-pro" style="height: {{ percent_ca_pro }}%">
                                                <span class="bar-label">{{ (y.ca_pro / 1000)|number_format(2, ',', ' ') }} K</span>
                                            </span>
                                        </div>

                                        <span class="years">{{ y.label }}</span>

                                        <div class="metric metric-bottom">
                                            <span class="col-pro" style="height: {{ percent_vol_pro }}%">
                                                <span class="bar-label">{{ y.vol_pro|number_format(0, ',', ' ') }}</span>
                                            </span>
                                            <span class="col-part" style="height: {{ percent_vol_part }}%">
                                                <span class="bar-label">{{ y.vol_part|number_format(0, ',', ' ') }}</span>
                                            </span>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>

                            <div class="panel-tools bottom">
                                <span class="panel-tools-title">Controles</span>
                            </div>
                        </div>
                    </div>

                    <div class="stats-wrapper graphique" data-pro-charts='{{ proCharts|json_encode|e('html_attr') }}'>
                        <div class="chart-toolbar">
                            <button type="button" class="chart-toggle active" data-chart-kind="ca">CA</button>
                            <button type="button" class="chart-toggle" data-chart-kind="volumes">Controles</button>
                        </div>
                        <div class="chart-canvas-wrap">
                            <canvas class="pro-chart-canvas" aria-label="Comparatif {{ referenceYear - 2 }} a {{ referenceYear }}"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="print-centre-tables-page">
            <div class="stats-wrapper">
                <div class="stats-panel table-panel">
                    <h2>Chiffres globaux du centre {{ referenceYear }}</h2>
                    <table class="table-pros pro-table-wrapper centre-activity-table">
                        <thead>
                        <tr>
                            <th>Indicateur</th>
                            <th>VTP</th>
                            <th>CLVTP</th>
                            <th>CV</th>
                            <th>CLCV</th>
                            <th>VTC</th>
                            <th>VOL</th>
                            <th>CLVOL</th>
                            <th>Total</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr>
                            <td class="left">CA HT</td>
                            <td>{{ activityTotals.ca_total_ht_vtp|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.ca_total_ht_clvtp|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.ca_total_ht_cv|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.ca_total_ht_clcv|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.ca_total_ht_vtc|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.ca_total_ht_vol|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.ca_total_ht_clvol|number_format(2, ',', ' ') }} €</td>
                            <td class="total">{{ activityTotals.ca_total_ht|number_format(2, ',', ' ') }} €</td>
                        </tr>
                        <tr>
                            <td class="left">Controles</td>
                            <td>{{ activityTotals.nb_vtp|number_format(0, ',', ' ') }}</td>
                            <td>{{ activityTotals.nb_clvtp|number_format(0, ',', ' ') }}</td>
                            <td>{{ activityTotals.nb_cv|number_format(0, ',', ' ') }}</td>
                            <td>{{ activityTotals.nb_clcv|number_format(0, ',', ' ') }}</td>
                            <td>{{ activityTotals.nb_vtc|number_format(0, ',', ' ') }}</td>
                            <td>{{ activityTotals.nb_vol|number_format(0, ',', ' ') }}</td>
                            <td>{{ activityTotals.nb_clvol|number_format(0, ',', ' ') }}</td>
                            <td class="total">{{ activityTotals.nb_controles|number_format(0, ',', ' ') }}</td>
                        </tr>
                        <tr>
                            <td class="left">Prix moyen</td>
                            <td>{{ activityTotals.prix_moyen_vtp|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.prix_moyen_clvtp|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.prix_moyen_cv|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.prix_moyen_clcv|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.prix_moyen_vtc|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.prix_moyen_vol|number_format(2, ',', ' ') }} €</td>
                            <td>{{ activityTotals.prix_moyen_clvol|number_format(2, ',', ' ') }} €</td>
                            <td class="total">{{ activityTotals.nb_controles > 0 ? (activityTotals.ca_total_ht / activityTotals.nb_controles)|number_format(2, ',', ' ') ~ ' €' : '0,00 €' }}</td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            {% for metric in [
                {'key': 'ca', 'title': 'CA mensuel par salarie', 'total': 'ca_total', 'currency': true},
                {'key': 'volumes', 'title': 'Controles mensuels par salarie', 'total': 'volumes_total', 'currency': false},
            ] %}
                <div class="stats-wrapper print-salaries-table">
                    <div class="stats-panel table-panel">
                        <h2>{{ metric.title }} {{ referenceYear }}</h2>
                        <table class="grid-panel-table" data-print-fit="1">
                            <thead>
                            <tr>
                                <th>Salarie</th>
                                {% for month in monthlySalaries.months %}
                                    <th>{{ month }}</th>
                                {% endfor %}
                                <th>Total</th>
                            </tr>
                            </thead>
                            <tbody>
                            {% for salarie in monthlySalaries.salaries %}
                                <tr>
                                    <td class="left wrap">{{ salarie.name }}</td>
                                    {% for monthNumber, month in monthlySalaries.months %}
                                        {% set value = salarie[metric.key][monthNumber] %}
                                        <td>
                                            {% if metric.currency %}
                                                {{ value|number_format(2, ',', ' ') }} €
                                            {% else %}
                                                {{ value|number_format(0, ',', ' ') }}
                                            {% endif %}
                                        </td>
                                    {% endfor %}
                                    <td class="total">
                                        {% if metric.currency %}
                                            {{ salarie[metric.total]|number_format(2, ',', ' ') }} €
                                        {% else %}
                                            {{ salarie[metric.total]|number_format(0, ',', ' ') }}
                                        {% endif %}
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="14">Aucune donnee de salarie sur la periode selectionnee.</td>
                                </tr>
                            {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
{% endblock %}
