{% extends 'cts/suivis/print/_base.html.twig' %}

{% set printTitle = 'Suivi activité' %}
{% set printOrientation = 'landscape' %}
{% set autoPrint = true %}
{% set printVariant = 'activite' %}

{% block content %}
    <div class="table-wrapper" data-print-fit="1">
        <table data-activity-table>
            <thead>
            <tr>
                <th>Centre</th>
                <th data-activity-column data-type-family="VTP" data-vehicle-family="VL">VTP</th>
                <th data-activity-column data-type-family="VTP" data-vehicle-family="CL">CLVTP</th>
                <th data-activity-column data-type-family="CV" data-vehicle-family="VL">CV</th>
                <th data-activity-column data-type-family="CV" data-vehicle-family="CL">CLCV</th>
                <th data-activity-column data-type-family="VTC" data-vehicle-family="VL">VTC</th>
                <th data-activity-column data-type-family="VOL" data-vehicle-family="VL">VOL</th>
                <th data-activity-column data-type-family="VOL" data-vehicle-family="CL">CLVOL</th>
                <th>Total</th>
                <th data-activity-column data-type-family="VTP" data-vehicle-family="VL">CA VTP</th>
                <th data-activity-column data-type-family="VTP" data-vehicle-family="CL">CA CLVTP</th>
                <th data-activity-column data-type-family="CV" data-vehicle-family="VL">CA CV</th>
                <th data-activity-column data-type-family="CV" data-vehicle-family="CL">CA CLCV</th>
                <th data-activity-column data-type-family="VTC" data-vehicle-family="VL">CA VTC</th>
                <th data-activity-column data-type-family="VOL" data-vehicle-family="VL">CA VOL</th>
                <th data-activity-column data-type-family="VOL" data-vehicle-family="CL">CA CLVOL</th>
                <th>Total CA</th>
                <th data-activity-column data-type-family="VTP" data-vehicle-family="VL">Prix VTP</th>
                <th data-activity-column data-type-family="VTP" data-vehicle-family="CL">Prix CLVTP</th>
                <th data-activity-column data-type-family="CV" data-vehicle-family="VL">Prix CV</th>
                <th data-activity-column data-type-family="CV" data-vehicle-family="CL">Prix CLCV</th>
                <th data-activity-column data-type-family="VTC" data-vehicle-family="VL">Prix VTC</th>
                <th data-activity-column data-type-family="VOL" data-vehicle-family="VL">Prix VOL</th>
                <th data-activity-column data-type-family="VOL" data-vehicle-family="CL">Prix CLVOL</th>
            </tr>
            </thead>

            <tbody>
            {% for societe, centres in synthese %}
                {% for agrCentre, centreData in centres %}
                    <tr class="total-row recap">
                        <td class="sticky-centre total">
                            {{ centreData.centre.reseau }} {{ centreData.centre.ville }} {{ agrCentre }}
                            {% if centreData.centre.agr_cl is not empty %}
                                - {{ centreData.centre.agr_cl }}
                            {% endif %}
                        </td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ centreData.totaux.nb_vtp }}</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ centreData.totaux.nb_clvtp }}</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ centreData.totaux.nb_cv }}</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ centreData.totaux.nb_clcv }}</td>
                        <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ centreData.totaux.nb_vtc }}</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ centreData.totaux.nb_vol }}</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ centreData.totaux.nb_clvol }}</td>
                        <td>{{ centreData.totaux.nb_controles }}</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ centreData.totaux.ca_total_ht_vtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ centreData.totaux.ca_total_ht_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ centreData.totaux.ca_total_ht_cv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ centreData.totaux.ca_total_ht_clcv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ centreData.totaux.ca_total_ht_vtc | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ centreData.totaux.ca_total_ht_vol | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ centreData.totaux.ca_total_ht_clvol | number_format(2, ',', ' ') }}€</td>
                        <td class="total">{{ centreData.totaux.ca_total_ht | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ centreData.totaux.prix_moyen_vtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ centreData.totaux.prix_moyen_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ centreData.totaux.prix_moyen_cv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ centreData.totaux.prix_moyen_clcv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ centreData.totaux.prix_moyen_vtc | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ centreData.totaux.prix_moyen_vol | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ centreData.totaux.prix_moyen_clvol | number_format(2, ',', ' ') }}€</td>
                    </tr>
                {% endfor %}

                {% set societeTotal = societeTotals[societe] ?? null %}
                {% if societeTotal %}
                    <tr class="total-row recap societe">
                        <td class="sticky-societe">{{ societe }}</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ societeTotal.nb_vtp }}</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ societeTotal.nb_clvtp }}</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ societeTotal.nb_cv }}</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ societeTotal.nb_clcv }}</td>
                        <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ societeTotal.nb_vtc }}</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ societeTotal.nb_vol }}</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ societeTotal.nb_clvol }}</td>
                        <td>{{ societeTotal.nb_controles }}</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ societeTotal.ca_total_ht_vtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ societeTotal.ca_total_ht_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ societeTotal.ca_total_ht_cv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ societeTotal.ca_total_ht_clcv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ societeTotal.ca_total_ht_vtc | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ societeTotal.ca_total_ht_vol | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ societeTotal.ca_total_ht_clvol | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ societeTotal.prix_moyen_vtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ societeTotal.prix_moyen_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ societeTotal.prix_moyen_cv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ societeTotal.prix_moyen_clcv | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ societeTotal.prix_moyen_vtc | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ societeTotal.prix_moyen_vol | number_format(2, ',', ' ') }}€</td>
                        <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ societeTotal.prix_moyen_clvol | number_format(2, ',', ' ') }}€</td>
                    </tr>
                {% endif %}
            {% endfor %}

            {% if globalTotals is defined %}
                <tr class="total-row global recap">
                    <td class="sticky-total">
                        TOUS RESEAUX / SOCIETES
                    </td>
                    <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ globalTotals.nb_vtp }}</td>
                    <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ globalTotals.nb_clvtp }}</td>
                    <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ globalTotals.nb_cv }}</td>
                    <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ globalTotals.nb_clcv }}</td>
                    <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ globalTotals.nb_vtc }}</td>
                    <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ globalTotals.nb_vol }}</td>
                    <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ globalTotals.nb_clvol }}</td>
                    <td>{{ globalTotals.nb_controles }}</td>
                    <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ globalTotals.ca_total_ht_vtp | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ globalTotals.ca_total_ht_clvtp | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ globalTotals.ca_total_ht_cv | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ globalTotals.ca_total_ht_clcv | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ globalTotals.ca_total_ht_vtc | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ globalTotals.ca_total_ht_vol | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ globalTotals.ca_total_ht_clvol | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VTP" data-vehicle-family="VL">{{ globalTotals.prix_moyen_vtp | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VTP" data-vehicle-family="CL">{{ globalTotals.prix_moyen_clvtp | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="CV" data-vehicle-family="VL">{{ globalTotals.prix_moyen_cv | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="CV" data-vehicle-family="CL">{{ globalTotals.prix_moyen_clcv | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VTC" data-vehicle-family="VL">{{ globalTotals.prix_moyen_vtc | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VOL" data-vehicle-family="VL">{{ globalTotals.prix_moyen_vol | number_format(2, ',', ' ') }}€</td>
                    <td data-activity-column data-type-family="VOL" data-vehicle-family="CL">{{ globalTotals.prix_moyen_clvol | number_format(2, ',', ' ') }}€</td>
                </tr>
            {% endif %}
            </tbody>
        </table>
    </div>
{% endblock %}
