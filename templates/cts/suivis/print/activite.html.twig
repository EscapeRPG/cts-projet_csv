{% extends 'cts/suivis/print/_base.html.twig' %}

{% set printTitle = 'Suivi activite' %}
{% set printOrientation = 'landscape' %}
{% set autoPrint = true %}
{% set printVariant = 'activite' %}

{% block content %}
    <div class="table-wrapper" data-print-fit="1">
        <table data-activity-table>
            <thead>
            <tr>
                <th class="sticky-salarie-name">Contrôleur</th>
                <th class="sticky-salarie-agr">Agrément</th>
                <th>VTP</th>
                <th>CLVTP</th>
                <th>CV</th>
                <th>CLCV</th>
                <th>VTC</th>
                <th>VOL</th>
                <th>CLVOL</th>
                <th>Total</th>
                <th>CA VTP</th>
                <th>CA CLVTP</th>
                <th>CA CV</th>
                <th>CA CLCV</th>
                <th>CA VTC</th>
                <th>CA VOL</th>
                <th>CA CLVOL</th>
                <th>Total CA</th>
                <th>Prix VTP</th>
                <th>Prix CLVTP</th>
                <th>Prix CV</th>
                <th>Prix CLCV</th>
                <th>Prix VTC</th>
                <th>Prix VOL</th>
                <th>Prix CLVOL</th>
            </tr>
            </thead>

            <tbody>
            {% for societe, centres in synthese %}
                {% for agrCentre, centreData in centres %}
                    {% for salarie in centreData.salaries %}
                        <tr>
                            <td class="sticky-salarie-name">{{ salarie.nom }} {{ salarie.prenom }}</td>
                            <td class="sticky-salarie-agr">
                                {{ salarie.agr }}
                                {% if salarie.agr_cl is not empty %}
                                    - {{ salarie.agr_cl }}
                                {% endif %}
                            </td>
                            <td class="int-row">{{ salarie.nb_vtp }}</td>
                            <td class="int-row">{{ salarie.nb_clvtp }}</td>
                            <td class="int-row">{{ salarie.nb_cv }}</td>
                            <td class="int-row">{{ salarie.nb_clcv }}</td>
                            <td class="int-row">{{ salarie.nb_vtc }}</td>
                            <td class="int-row">{{ salarie.nb_vol }}</td>
                            <td class="int-row">{{ salarie.nb_clvol }}</td>
                            <td class="int-row total">{{ salarie.nb_controles }}</td>
                            <td class="int-row">{{ salarie.total_ht_vtp | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.total_ht_clvtp | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.total_ht_cv | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.total_ht_clcv | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.total_ht_vtc | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.total_ht_vol | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.total_ht_clvol | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row total">{{ salarie.total_presta_ht | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.prix_moyen_vtp | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.prix_moyen_clvtp | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.prix_moyen_cv | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.prix_moyen_clcv | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.prix_moyen_vtc | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.prix_moyen_vol | number_format(2, ',', ' ') }}€</td>
                            <td class="int-row">{{ salarie.prix_moyen_clvol | number_format(2, ',', ' ') }}€</td>
                        </tr>
                    {% endfor %}

                    <tr class="total-row recap">
                        <td colspan="2" class="sticky-centre total">
                            {{ centreData.centre.reseau }} {{ centreData.centre.ville }} {{ agrCentre }}
                            {% if centreData.centre.agr_cl is not empty %}
                                - {{ centreData.centre.agr_cl }}
                            {% endif %}
                        </td>
                        <td>{{ centreData.totaux.nb_vtp }}</td>
                        <td>{{ centreData.totaux.nb_clvtp }}</td>
                        <td>{{ centreData.totaux.nb_cv }}</td>
                        <td>{{ centreData.totaux.nb_clcv }}</td>
                        <td>{{ centreData.totaux.nb_vtc }}</td>
                        <td>{{ centreData.totaux.nb_vol }}</td>
                        <td>{{ centreData.totaux.nb_clvol }}</td>
                        <td>{{ centreData.totaux.nb_controles }}</td>
                        <td>{{ centreData.totaux.ca_total_ht_vtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.ca_total_ht_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.ca_total_ht_cv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.ca_total_ht_clcv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.ca_total_ht_vtc | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.ca_total_ht_vol | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.ca_total_ht_clvol | number_format(2, ',', ' ') }}€</td>
                        <td class="total">{{ centreData.totaux.ca_total_ht | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.prix_moyen_vtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.prix_moyen_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.prix_moyen_cv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.prix_moyen_clcv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.prix_moyen_vtc | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.prix_moyen_vol | number_format(2, ',', ' ') }}€</td>
                        <td>{{ centreData.totaux.prix_moyen_clvol | number_format(2, ',', ' ') }}€</td>
                    </tr>
                {% endfor %}

                {% set societeTotal = societeTotals[societe] ?? null %}
                {% if societeTotal %}
                    <tr class="total-row recap societe">
                        <td class="sticky-societe" colspan="2">{{ societe }}</td>
                        <td>{{ societeTotal.nb_vtp }}</td>
                        <td>{{ societeTotal.nb_clvtp }}</td>
                        <td>{{ societeTotal.nb_cv }}</td>
                        <td>{{ societeTotal.nb_clcv }}</td>
                        <td>{{ societeTotal.nb_vtc }}</td>
                        <td>{{ societeTotal.nb_vol }}</td>
                        <td>{{ societeTotal.nb_clvol }}</td>
                        <td>{{ societeTotal.nb_controles }}</td>
                        <td>{{ societeTotal.ca_total_ht_vtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht_cv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht_clcv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht_vtc | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht_vol | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht_clvol | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.ca_total_ht | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.prix_moyen_vtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.prix_moyen_clvtp | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.prix_moyen_cv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.prix_moyen_clcv | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.prix_moyen_vtc | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.prix_moyen_vol | number_format(2, ',', ' ') }}€</td>
                        <td>{{ societeTotal.prix_moyen_clvol | number_format(2, ',', ' ') }}€</td>
                    </tr>
                {% endif %}
            {% endfor %}

            {% if globalTotals is defined %}
                <tr class="total-row global recap">
                    <td class="sticky-total" colspan="2">
                        TOUS RESEAUX / SOCIETES
                    </td>
                    <td>{{ globalTotals.nb_vtp }}</td>
                    <td>{{ globalTotals.nb_clvtp }}</td>
                    <td>{{ globalTotals.nb_cv }}</td>
                    <td>{{ globalTotals.nb_clcv }}</td>
                    <td>{{ globalTotals.nb_vtc }}</td>
                    <td>{{ globalTotals.nb_vol }}</td>
                    <td>{{ globalTotals.nb_clvol }}</td>
                    <td>{{ globalTotals.nb_controles }}</td>
                    <td>{{ globalTotals.ca_total_ht_vtp | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht_clvtp | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht_cv | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht_clcv | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht_vtc | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht_vol | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht_clvol | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.ca_total_ht | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.prix_moyen_vtp | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.prix_moyen_clvtp | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.prix_moyen_cv | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.prix_moyen_clcv | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.prix_moyen_vtc | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.prix_moyen_vol | number_format(2, ',', ' ') }}€</td>
                    <td>{{ globalTotals.prix_moyen_clvol | number_format(2, ',', ' ') }}€</td>
                </tr>
            {% endif %}
            </tbody>
        </table>
    </div>
{% endblock %}
