{% extends 'base.html.twig' %}

{% block title %}Suivi centres{% endblock %}

{% block body %}
    <div class="suivi-container">
        {% include 'partials/filters.html.twig' %}

        <div class="activite-infos">
            <p>Tous prix indiqués HT</p>
        </div>

        <div class="pro-stats-container" data-ajax-results>
            <div class="pro-stats-panel">
                <div class="summary">
                    <div class="ca-summary">
                        <h2>CA {{ "now"|date('Y') }}</h2>
                        <strong>{{ summary.ca_now|number_format(2, ',', ' ') }} €</strong>

                        <div class="previous">
                            <div class="row">
                                <strong>{{ "now"|date('Y') - 1 }}</strong>
                                {{ summary.ca_n1|number_format(2, ',', ' ') }} €
                                <div
                                    class="{{ summary.per_ca_n1 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ca_n1|number_format(2, ',', ' ') }}
                                    %
                                </div>
                            </div>

                            <div class="row">
                                <strong>{{ "now"|date('Y') - 2 }}</strong>
                                {{ summary.ca_n2|number_format(2, ',', ' ') }} €
                                <div
                                    class="{{ summary.per_ca_n2 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ca_n2|number_format(2, ',', ' ') }}
                                    %
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="ca-summary">
                        <h2>Contrôles {{ "now"|date('Y') }}</h2>
                        <strong>{{ summary.vol_now|number_format(0, ',', ' ') }}</strong>

                        <div class="previous">
                            <div class="row">
                                <strong>{{ "now"|date('Y') - 1 }}</strong>
                                {{ summary.vol_n1|number_format(0, ',', ' ') }}
                                <div
                                    class="{{ summary.per_ctrl_n1 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ctrl_n1|number_format(2, ',', ' ') }}
                                    %
                                </div>
                            </div>

                            <div class="row">
                                <strong>{{ "now"|date('Y') - 2 }}</strong>
                                {{ summary.vol_n2|number_format(0, ',', ' ') }}
                                <div
                                    class="{{ summary.per_ctrl_n2 < 0 ? 'decreased' : 'increased' }}">{{ summary.per_ctrl_n2|number_format(2, ',', ' ') }}
                                    %
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="summary">
                    <div class="pro-part-panel">
                        {% set years = [
                            {'label': ("now"|date('Y') - 2), 'ca_part': splitSummary.ca_part_n2, 'ca_pro': splitSummary.ca_pro_n2, 'vol_part': splitSummary.vol_part_n2, 'vol_pro': splitSummary.vol_pro_n2},
                            {'label': ("now"|date('Y') - 1), 'ca_part': splitSummary.ca_part_n1, 'ca_pro': splitSummary.ca_pro_n1, 'vol_part': splitSummary.vol_part_n1, 'vol_pro': splitSummary.vol_pro_n1},
                            {'label': ("now"|date('Y')),     'ca_part': splitSummary.ca_part_now, 'ca_pro': splitSummary.ca_pro_now, 'vol_part': splitSummary.vol_part_now, 'vol_pro': splitSummary.vol_pro_now},
                        ] %}

                        {% set max_ca_total = max(
                            splitSummary.ca_part_n2 + splitSummary.ca_pro_n2,
                            splitSummary.ca_part_n1 + splitSummary.ca_pro_n1,
                            splitSummary.ca_part_now + splitSummary.ca_pro_now
                        ) %}
                        {% set max_vol_total = max(
                            splitSummary.vol_part_n2 + splitSummary.vol_pro_n2,
                            splitSummary.vol_part_n1 + splitSummary.vol_pro_n1,
                            splitSummary.vol_part_now + splitSummary.vol_pro_now
                        ) %}

                        <div class="panel-tools">
                            <span class="panel-tools-title">CA</span>
                            <div class="legende">
                                <div class="part"></div>
                                Part
                                <div class="pro"></div>
                                Pros
                            </div>
                        </div>

                        <div class="ca-pro-part">
                            {% for y in years %}
                                {% set percent_ca_part = max_ca_total > 0 ? (y.ca_part * 100 / max_ca_total) : 0 %}
                                {% set percent_ca_pro = max_ca_total > 0 ? (y.ca_pro * 100 / max_ca_total) : 0 %}
                                {% set percent_vol_part = max_vol_total > 0 ? (y.vol_part * 100 / max_vol_total) : 0 %}
                                {% set percent_vol_pro = max_vol_total > 0 ? (y.vol_pro * 100 / max_vol_total) : 0 %}

                                <div class="col-pro-part">
                                    <div class="metric metric-top">
                                        <span class="col-part" style="height: {{ percent_ca_part }}%">
                                            <span class="bar-label">{{ (y.ca_part / 1000)|number_format(2, ',', ' ') }} K</span>
                                        </span>
                                        <span class="col-pro" style="height: {{ percent_ca_pro }}%">
                                            <span class="bar-label">{{ (y.ca_pro / 1000)|number_format(2, ',', ' ') }} K</span>
                                        </span>
                                    </div>

                                    <span class="years">{{ y.label }}</span>

                                    <div class="metric metric-bottom">
                                        <span class="col-pro" style="height: {{ percent_vol_pro }}%">
                                            <span class="bar-label">{{ y.vol_pro|number_format(0, ',', ' ') }}</span>
                                        </span>
                                        <span class="col-part" style="height: {{ percent_vol_part }}%">
                                            <span class="bar-label">{{ y.vol_part|number_format(0, ',', ' ') }}</span>
                                        </span>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        <div class="panel-tools bottom">
                            <span class="panel-tools-title">Contrôles</span>
                        </div>
                    </div>
                </div>

                <div class="stats-wrapper graphique"
                     data-pro-charts='{{ proCharts|json_encode|e('html_attr') }}'>
                    <div class="chart-toolbar">
                        <button type="button" class="chart-toggle active" data-chart-kind="ca">CA</button>
                        <button type="button" class="chart-toggle" data-chart-kind="volumes">Contrôles</button>
                    </div>
                    <div class="chart-canvas-wrap">
                        <canvas class="pro-chart-canvas"
                                aria-label="Comparatif {{ "now"|date('Y') - 2 }} à {{ "now"|date('Y') }}"></canvas>
                    </div>
                </div>
            </div>

            <div class="stats-wrapper">
                <div class="stats-panel table-panel">
                    <table class="table-pros pro-table-wrapper">
                        <thead>
                        <tr>
                            <th>Centre</th>
                            <th>CA N</th>
                            <th>CA N-1</th>
                            <th>CA N-2</th>
                            <th>CA // N-1</th>
                            <th>CA // N-2</th>
                            <th>Vol. N</th>
                            <th>Vol. N-1</th>
                            <th>Vol. N-2</th>
                            <th>Vol. // N-1</th>
                            <th>Vol. // N-2</th>
                        </tr>
                        </thead>

                        <tbody>
                        {% for client in clients %}
                            <tr>
                                <td>{{ client.nom }}
                                    <small>({{ client.societe }}{% if client.reseau is not empty %} - {{ client.reseau }}{% endif %}
                                        )</small></td>
                                <td class="{{ client.ca_now < client.ca_n1 ? 'malus' : 'bonus' }} right">{{ client.ca_now|number_format(2, ',', ' ') }}
                                    €
                                </td>
                                <td class="right">{{ client.ca_n1|number_format(2, ',', ' ') }} €</td>
                                <td class="right">{{ client.ca_n2|number_format(2, ',', ' ') }} €</td>
                                <td class="{{ client.per_ca_n1 < 0 ? 'decreased' : 'increased' }}">{{ client.per_ca_n1|number_format(2, ',', ' ') }}
                                    %
                                </td>
                                <td class="{{ client.per_ca_n2 < 0 ? 'decreased' : 'increased' }}">{{ client.per_ca_n2|number_format(2, ',', ' ') }}
                                    %
                                </td>
                                <td>{{ client.nb_ctrl_now }}</td>
                                <td>{{ client.nb_ctrl_n1 }}</td>
                                <td>{{ client.nb_ctrl_n2 }}</td>
                                <td class="{{ client.per_n1 < 0 ? 'decreased' : 'increased' }}">{{ client.per_n1|number_format(2, ',', ' ') }}
                                    %
                                </td>
                                <td class="{{ client.per_n2 < 0 ? 'decreased' : 'increased' }}">{{ client.per_n2|number_format(2, ',', ' ') }}
                                    %
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
