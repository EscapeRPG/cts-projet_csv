{% extends 'base.html.twig' %}

{% block title %}Liste des centres{% endblock %}

{% block body %}
    <div class="search-list">
        <label for="cts-centres-search">Recherche :</label>
        <input id="cts-centres-search"
               type="search"
               autocomplete="off"
               placeholder="Agr, ville, réseau..."
               value="{{ app.request.query.get('q') }}"
               data-list-search-input="1"
               data-list-search-partial-url="{{ path('app_centres_list_partial') }}"
               data-list-search-push-url="{{ path('app_centres_list') }}"
               data-list-search-results="#cts-centres-results">
        <small data-list-search-blocked-message hidden>Veuillez enregistrer vos modifications pour effectuer une recherche.</small>
    </div>

    <div class="container">
        <div id="cts-centres-results" data-list-results-container="1">
            {{ include('cts/centres/_list_results.html.twig') }}
        </div>
    </div>

    {% set errorsMessages = app.flashes('error') %}
    {% if errorsMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h3>Erreurs détectées</h3>
                <ul>
                    {% for error in errorsMessages %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% set successMessages = app.flashes('success') %}
    {% if successMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal success-modal" data-modals-target="modal">
                <h2>Succès</h2>

                {% for message in successMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    {% set warningMessages = app.flashes('warning') %}
    {% if warningMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h2>Attention</h2>

                {% for message in warningMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}
{% endblock %}
