<div class="annees-filter">
    {% for annee in annees %}
    <a href="{{ path(app.request.attributes.get('_route'), { annee: annee }) }}"
       data-year-value="{{ annee }}"
       class="{{ annee == anneeCourante ? 'active' }}">
        {{ annee }}
    </a>
    {% endfor %}

    <a href="{{ path(app.request.attributes.get('_route')) }}"
       data-year-value=""
       class="{{ anneeCourante is null ? 'active' }}">
        3 dernières
    </a>
</div>
