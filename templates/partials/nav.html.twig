        <div class="burgerBtn">
            <span id="burger" data-burger-target="burger"></span>
        </div>
    </div>

    <div id="responsive" data-burger-target="menu">
        <div>
            {% if is_granted('IS_AUTHENTICATED') %}
                <h3>{{ user.username }}</h3>
                <h3>{{ ('ROLE_ADMIN' in user.roles) ? 'Administrateur' : 'Utilisateur' }}</h3>

                <ul class="profil">
                    <li>
                        <a href="{{ path('app_profile', { id: app.user.id }) }}">
                            Profil
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_logout') }}">
                            Se déconnecter
                        </a>
                    </li>
                </ul>
            {% endif %}

            {% if is_granted('ROLE_ADMIN') %}
                <h2>ESPACE ADMIN</h2>

                <h3 class="toggle">
                    <span class="toggle-title">
                        {{ include('partials/svg/utilisateurs.html.twig') }}
                        Utilisateurs
                    </span>
                    <span class="open-btn">></span>
                </h3>
                <ul class="menu">
                    <li>
                        <a href="{{ path('app_users_list') }}">
                            → Liste des utilisateurs
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_users_add') }}">
                            → Ajouter un utilisateur
                        </a>
                    </li>
                </ul>

                <h3 class="toggle">
                    <span class="toggle-title">
                        {{ include('partials/svg/societes.html.twig') }}
                        Sociétés
                    </span>
                    <span class="open-btn">></span>
                </h3>
                <ul class="menu">
                    <li>
                        <a href="{{ path('app_societes_list') }}">
                            → Liste des sociétés
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_societes_add') }}">
                            → Ajouter une société
                        </a>
                    </li>
                </ul>

                <h3 class="toggle">
                    <span class="toggle-title">
                        {{ include('partials/svg/centres.html.twig') }}
                        Centres
                    </span>
                    <span class="open-btn">></span>
                </h3>
                <ul class="menu">
                    <li>
                        <a href="{{ path('app_centres_list') }}">
                            → Liste des centres
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_centres_add') }}">
                            → Ajouter un centre
                        </a>
                    </li>
                </ul>

                <h3 class="toggle">
                    <span class="toggle-title">
                        {{ include('partials/svg/salaries.html.twig') }}
                        Salariés
                    </span>
                    <span class="open-btn">></span>
                </h3>
                <ul class="menu">
                    <li>
                        <a href="{{ path('app_salaries_list_uneditable') }}">
                            → Liste des salariés
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_salaries_add') }}">
                            → Ajouter un salarié
                        </a>
                    </li>
                </ul>

            {% endif %}

            {% if is_granted('IS_AUTHENTICATED') %}
                <h2>Suivis</h2>
                <h3 class="toggle">
                    <span class="toggle-title">
                        {{ include('partials/svg/activite.html.twig') }}
                        Activité
                    </span>
                    <span class="open-btn">></span>
                </h3>
                <ul class="menu">
                    <li>
                        <a href="{{ path('app_suivi_activite') }}">
                            → Synthèse
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_suivi_centres') }}">
                            → Centres
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_suivi_focus_pro') }}">
                            → Clients pros
                        </a>
                    </li>
                    <li>
                        <a href="{{ path('app_suivi_controleurs') }}">
                            → Contrôleurs
                        </a>
                    </li>
                </ul>
            {% else %}
                <ul class="profil">
                    <li>
                        <a href="{{ path('app_login') }}">
                            → Se connecter
                        </a>
                    </li>
                </ul>
            {% endif %}
        </div>

        <div>
            <p class="meta-info">
                Dernière mise à jour BDD :
                <br>
                {% if database_last_update_at is not null %}
                    {{ database_last_update_at|format_datetime(
                        pattern: "d MMMM y ' - ' HH:mm",
                        locale: 'fr'
                    ) }}
                {% else %}
                    inconnue
                {% endif %}
                <br>
                <br>
                Réseau manquant : Autosur
            </p>
        </div>
    </div>
</nav>

<div class="notif-return" data-controller="notif">
    <div class="notifications">
        <img src="{{ asset('img/cloche.png') }}"
             class="{{ unread_notifications_count > 0 ? 'unread-alert' : '' }}"
             alt="notifications"
             data-action="click->notif#notifications"
             data-notif-target="btn">

        <div class="notif-nbr {{ unread_notifications_count > 0 ? 'active' : '' }}" data-notif-target="count">
            {% if unread_notifications_count > 0 %}
                {{ unread_notifications_count }}
            {% endif %}
        </div>
    </div>

    <div class="notif-responsive" data-notif-target="panel">
        {% if notifications is empty %}
            <p data-notif-target="emptyState">Aucune notification.</p>
        {% else %}
            {% for userNotification in notifications %}
                {% set notification = userNotification.notification %}
                <article class="notif-item {{ userNotification.readAt is null ? 'unread' : 'read' }}"
                         data-notif-target="item">
                    <p>{{ notification_display_message(notification) }}</p>

                    <button
                        type="button"
                        class="notif-dismiss"
                        aria-label="Marquer comme lue"
                        data-action="click->notif#markAsRead"
                        data-url="{{ path('app_notifications_read', { id: userNotification.id }) }}"
                        data-token="{{ csrf_token('read-notification-' ~ userNotification.id) }}"
                    >x
                    </button>
                </article>
            {% endfor %}
            <p data-notif-target="emptyState" hidden>Aucune notification.</p>
        {% endif %}
    </div>

    <a href="{{ path('app_home') }}" class="home">
        <img src="{{ asset('img/logo.png') }}" alt="accueil" title="Retour à l'accueil">
    </a>
</div>
