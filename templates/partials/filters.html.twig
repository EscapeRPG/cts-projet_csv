<div class="sidenav">
    {% set route = app.request.attributes.get('_route') %}

    <div class="onglets">
        <a href="{{ path('app_suivi_activite') }}"
           data-keep-filters="1"
           data-keep-filters-base-href="{{ path('app_suivi_activite') }}"
           class="{{ route == 'app_suivi_activite' ? 'active' : '' }}">Synthèse</a>
        <a href="{{ path('app_suivi_centres') }}"
           data-keep-filters="1"
           data-keep-filters-base-href="{{ path('app_suivi_centres') }}"
           class="{{ route == 'app_suivi_centres' ? 'active' : '' }}">Tous les centres</a>
        <a href="{{ path('app_suivi_centres') }}"
           data-keep-filters="1"
           data-keep-filters-base-href="{{ path('app_suivi_centre_details') }}"
           class="{{ route == 'app_suivi_centre_details' ? 'active' : '' }}">Détails par centre</a>
        <a href="{{ path('app_suivi_focus_pro') }}"
           data-keep-filters="1"
           data-keep-filters-base-href="{{ path('app_suivi_focus_pro') }}"
           class="{{ route == 'app_suivi_focus_pro' ? 'active' : '' }}">Clients pros</a>
        <a href="{{ path('app_suivi_controleurs') }}"
           data-keep-filters="1"
           data-keep-filters-base-href="{{ path('app_suivi_controleurs') }}"
           class="{{ route == 'app_suivi_controleurs' ? 'active' : '' }}">Contrôleurs</a>
        <a href="{{ path('app_suivi_modes_reglement') }}"
           data-keep-filters="1"
           data-keep-filters-base-href="{{ path('app_suivi_modes_reglement') }}"
           class="{{ route == 'app_suivi_modes_reglement' ? 'active' : '' }}">Modes règlement</a>
    </div>

    <form method="get"
          class="filter-form"
          data-dependent-url="{{ path('app_suivi_filters_dependent') }}"
          data-current-route="{{ route }}"
          {% if route == 'app_suivi_centres' %}data-preserve-query-params="annee"{% endif %}
          data-preserve-centre-on-clear="{{ (is_granted('ROLE_CTS') and not is_granted('ROLE_ADMIN')) ? '1' : '0' }}">

        {% if route == 'app_suivi_modes_reglement' %}
            {% set data = selectedModesData|default('nb') %}
            {% set tableMode = selectedModesTable|default('centres') %}
            {% set aggregate = selectedAggregate|default('total') %}

            <fieldset class="filter-radio-group">
                <legend>Entités</legend>

                <label>
                    <input type="radio"
                           name="table"
                           value="centres"
                           {% if tableMode == 'centres' %}checked{% endif %}>
                    Centres
                </label>
                <label>
                    <input type="radio"
                           name="table"
                           value="salaries"
                           {% if tableMode == 'salaries' %}checked{% endif %}>
                    Contrôleurs
                </label>
            </fieldset>

            <fieldset class="filter-radio-group">
                <legend>Données</legend>

                <label>
                    <input type="radio"
                           name="data"
                           value="nb"
                           {% if data == 'nb' %}checked{% endif %}>
                    Nombre
                </label>
                <label>
                    <input type="radio"
                           name="data"
                           value="montant"
                           {% if data == 'montant' %}checked{% endif %}>
                    Montant
                </label>
            </fieldset>

            <fieldset class="filter-radio-group">
                <legend>Valeurs</legend>

                <label>
                    <input type="radio"
                           name="aggregate"
                           value="total"
                           {% if aggregate == 'total' %}checked{% endif %}>
                    Total
                </label>
                <label>
                    <input type="radio"
                           name="aggregate"
                           value="repartition"
                           {% if aggregate == 'repartition' %}checked{% endif %}>
                    Répartition
                </label>
            </fieldset>
        {% endif %}

        <div class="filters-container">
            <div class="filter-dropdown">
                <button type="button" class="dropdown-toggle">
                    Mois
                </button>

                <div class="dropdown-menu">
                    <div class="filter-actions">
                        <label class="filter-action-check">
                            <input type="checkbox" data-months-toggle-all>
                            Tous
                        </label>
                        <button type="button" data-months-select-ytd>Jan → Ajd</button>
                    </div>

                    {% for key, label in mois %}
                        <label>
                            <input type="checkbox"
                                   name="mois[]"
                                   value="{{ key }}"
                                   {% if key in selected.mois %}checked{% endif %}>
                            {{ label }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            {% if route != 'app_suivi_centre_details' %}
                <div class="filter-dropdown">
                    <button type="button" class="dropdown-toggle">
                        Réseaux
                    </button>

                    <div class="dropdown-menu">
                        {% for r in reseaux %}
                            {% set value = r is iterable ? (attribute(r, 'id') is defined ? attribute(r, 'id') : (attribute(r, 'nom') is defined ? attribute(r, 'nom') : '')) : r %}
                            {% set label = r is iterable ? (attribute(r, 'nom') is defined ? attribute(r, 'nom') : value) : r %}
                            {% if value != '' %}
                                <label>
                                    <input type="checkbox"
                                           name="reseau[]"
                                           value="{{ value }}"
                                           {% if value in selected.reseau %}checked{% endif %}>
                                    {{ label|capitalize }}
                                </label>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% if route != 'app_suivi_centre_details' %}
                <div class="filter-dropdown">
                    <button type="button" class="dropdown-toggle">
                        Sociétés
                    </button>

                    <div class="dropdown-menu">
                        {% for societe in societes %}
                            <label>
                                <input type="checkbox"
                                       name="societe[]"
                                       value="{{ societe }}"
                                       {% if societe in selected.societe %}checked{% endif %}>
                                {{ societe }}
                            </label>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% if route != 'app_suivi_centre_details' %}
                <div class="filter-dropdown">
                    <button type="button" class="dropdown-toggle">
                        Centres
                    </button>

                    <div class="dropdown-menu" data-filter-list="centre" data-filter-input-type="checkbox">
                        {% for centre in centres %}
                            <label>
                                <input type="checkbox" name="centre[]" value="{{ centre.agr_centre }}"
                                       {% if centre.agr_centre in selected.centre %}checked{% endif %}>
                                {{ centre.label }}
                            </label>
                        {% endfor %}
                    </div>
                </div>
            {% else %}
                <div class="filter-dropdown">
                    <button type="button" class="dropdown-toggle">
                        Centres
                    </button>

                    <div class="dropdown-menu" data-filter-list="centre" data-filter-input-type="radio">
                        {% for centre in centres %}
                            <label>
                                <input type="radio" name="centre[]" value="{{ centre.agr_centre }}"
                                       {% if centre.agr_centre in selected.centre %}checked{% endif %}>
                                {{ centre.label }}
                            </label>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            {% if route != 'app_suivi_focus_pro' and route != 'app_suivi_centre_details' %}
                <div class="filter-dropdown">
                    <button type="button" class="dropdown-toggle">
                        Contrôleurs
                    </button>

                    <div class="dropdown-menu" data-filter-list="controleur" data-filter-input-type="checkbox">
                        {% for c in controleurs %}
                            {% set value = c.id %}
                            <label>
                                <input type="checkbox"
                                       name="controleur[]"
                                       value="{{ value }}"
                                       {% if value in selected.controleur %}checked{% endif %}>
                                {{ c.nom }} {{ c.prenom }}
                            </label>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            <div class="filter-dropdown">
                <button type="button" class="dropdown-toggle">
                    Types
                </button>

                <div class="dropdown-menu">
                    {% for type in types_controles %}
                        <label>
                            <input type="checkbox"
                                   name="type[]"
                                   value="{{ type }}"
                                   {% if type in selected.type %}checked{% endif %}>
                            {{ type }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            <div class="filter-dropdown">
                <button type="button" class="dropdown-toggle">
                    Véhicules
                </button>

                <div class="dropdown-menu">
                    {% for vehicule in vehicules %}
                        <label>
                            <input type="checkbox"
                                   name="vehicule[]"
                                   value="{{ vehicule }}"
                                   {% if vehicule in selected.vehicule %}checked{% endif %}>
                            {{ vehicule }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            {% if anneeCourante is not null %}
                <input type="hidden" name="annee" value="{{ anneeCourante }}">
            {% endif %}
            <input type="hidden" name="vehicule_filter_present" value="1">

            <button type="button" data-clear-filters>Vider les filtres</button>
        </div>
    </form>
</div>
