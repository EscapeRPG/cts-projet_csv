<div class="sidenav">
    {% set route = app.request.attributes.get('_route') %}

    <div class="onglets">
        {# Keep href valid even when query contains arrays (societe[]). JS handles the AJAX switch. #}
        <a href="{{ path(route, { type: 'exploitation' }) }}"
           class="{{ type == 'exploitation' ? 'active' : '' }}"
           data-encours-type="exploitation">
            Exploitations
        </a>
        <a href="{{ path(route, { type: 'immobilier' }) }}"
           class="{{ type == 'immobilier' ? 'active' : '' }}"
           data-encours-type="immobilier">
            Immobilier
        </a>
    </div>

    <form method="get" class="filter-form" data-current-route="{{ route }}">
        {% set years = annees|default([])|sort %}
        {% set firstYear = years|first|default(null) %}
        {% set lastYear = years|last|default(null) %}

        <div class="encours-year-range">
            <div class="filter-dropdown" data-encours-year-from>
                <button type="button" class="dropdown-toggle">
                    Depuis
                </button>

                <div class="dropdown-menu">
                    {% for annee in years %}
                        <label>
                            <input type="radio"
                                   name="encours_year_from_ui"
                                   value="{{ annee }}"
                                   {% if anneeDepuis is not null and annee == anneeDepuis %}checked{% elseif anneeDepuis is null and loop.first %}checked{% endif %}>
                            {{ annee }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            <div class="filter-dropdown" data-encours-year-to>
                <button type="button" class="dropdown-toggle">
                    Jusqu'à
                </button>

                <div class="dropdown-menu">
                    {% for annee in years %}
                        <label>
                            <input type="radio"
                                   name="encours_year_to_ui"
                                   value="{{ annee }}"
                                   {% if anneeJusqua is not null and annee == anneeJusqua %}checked{% elseif anneeJusqua is null and loop.last %}checked{% endif %}>
                            {{ annee }}
                        </label>
                    {% endfor %}
                </div>
            </div>
        </div>

        <div class="filters-container">
            <div class="filter-dropdown">
                <button type="button" class="dropdown-toggle">
                    Sociétés
                </button>

                <div class="dropdown-menu">
                    {% for id, nom in societes %}
                        <label>
                            <input type="checkbox"
                                   name="societe[]"
                                   value="{{ id }}"
                                   {% if societeIds is defined and id in societeIds %}checked{% endif %}>
                            {{ nom }}
                        </label>
                    {% endfor %}
                </div>
            </div>

            {% if anneeDepuis is not null %}
                <input type="hidden" name="annee_debut" value="{{ anneeDepuis }}">
            {% elseif firstYear is not null %}
                <input type="hidden" name="annee_debut" value="{{ firstYear }}">
            {% endif %}
            {% if anneeJusqua is not null %}
                <input type="hidden" name="annee_fin" value="{{ anneeJusqua }}">
            {% elseif lastYear is not null %}
                <input type="hidden" name="annee_fin" value="{{ lastYear }}">
            {% endif %}

            <input type="hidden" name="type" value="{{ type|default('exploitation') }}">

            <button type="button" data-clear-filters>Vider les filtres</button>
        </div>
    </form>
</div>
