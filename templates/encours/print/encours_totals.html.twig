{% extends 'cts/suivis/print/_base.html.twig' %}

{% set printTitle = type == 'immobilier' ? 'Encours bancaires - Immobilier' : 'Encours bancaires - Exploitations' %}
{% set printOrientation = 'landscape' %}
{% set autoPrint = true %}
{% set printVariant = 'encours' %}

{% block content %}
    <div class="table-wrapper" data-print-fit="1">
        <table data-activity-table>
            <thead>
            <tr>
                <th>Société</th>
                <th>Centre</th>

                {% for annee in anneesAffichees|default(annees) %}
                    <th>Solde {{ annee }}</th>
                {% endfor %}
            </tr>
            </thead>

            <tbody>
            {% for societeNom, groupe in groupes %}
                <tr class="total-row recap societe">
                    <td class="sticky-societe">{{ societeNom }}</td>
                    <td>TOTAL ENCOURS</td>

                    {% for annee in anneesAffichees|default(annees) %}
                        {% set total = groupe.totauxParAnnee[annee]|default(0) %}
                        <td class="int-row">
                            {{ total|number_format(2, ',', ' ') }} €
                        </td>
                    {% endfor %}
                </tr>
            {% endfor %}

            {% if globalTotalsParAnnee is defined %}
                <tr class="total-row global recap">
                    <td class="sticky-total" colspan="2">TOTAL DES ENCOURS</td>

                    {% for annee in anneesAffichees|default(annees) %}
                        {% set total = globalTotalsParAnnee[annee]|default(0) %}
                        <td class="int-row">
                            {{ total|number_format(2, ',', ' ') }} €
                        </td>
                    {% endfor %}
                </tr>
            {% endif %}
            </tbody>
        </table>
    </div>
{% endblock %}

