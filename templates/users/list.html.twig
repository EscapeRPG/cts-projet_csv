{% extends 'base.html.twig' %}

{% macro accessClass(canView, canEdit, canAdd) %}
    {% if not canView %}
        decreased
    {% elseif (not canEdit) or (not canAdd) %}
        partially
    {% else %}
        increased
    {% endif %}
{% endmacro %}

{% import _self as ui %}

{% block title %}Liste des utilisateurs{% endblock %}

{% block body %}
    <div class="container">
        <div class="table-wrapper">
            <table class="users-list">
                <thead>
                <tr>
                    <th rowspan="2">Nom<br>d'utilisateur</th>
                    <th rowspan="2">Email</th>
                    <th rowspan="2">Rôle</th>
                    <th colspan="4">Organigrammes</th>
                    <th rowspan="2">Encours</th>
                    <th class="td-centres-selectlike" rowspan="2">Rattachement</th>
                    <th rowspan="2">Sociétés</th>
                    <th rowspan="2">Centres</th>
                    <th rowspan="2">Voitures</th>
                    <th rowspan="2">Salariés</th>
                    <th rowspan="2">Actions</th>
                    <th rowspan="2">Supprimer</th>
                </tr>

                <tr>
                    <th>Modifier</th>
                    <th>Structurel</th>
                    <th>Immobilier</th>
                    <th>Hiérarchique</th>
                </tr>
                </thead>

                <tbody>
                {% for userList in users %}
                    {% set roles = userList.roles %}
                    {% set isAdmin = 'ROLE_ADMIN' in roles %}

                    {# Organigrammes: "Editer" implique "Ajouter" (donc un seul indicateur). #}
                    {% set canEditOrganigrams = isAdmin or ('ROLE_ORGANIGRAM_EDIT' in roles) %}

                    {% set canViewOrganigrammeStructurel = isAdmin or ('ROLE_ORGANIGRAM_STRUCT_VIEW' in roles) %}
                    {% set canViewOrganigrammeImmobilier = isAdmin or ('ROLE_ORGANIGRAM_IMMO_VIEW' in roles) %}
                    {% set canViewOrganigrammeHierarchique = isAdmin or ('ROLE_ORGANIGRAM_HIERARCHY_VIEW' in roles) %}

                    {# Pour les colonnes "Structurel/Immobilier/Hierarchique" on affiche la lecture par onglet. #}
                    {% set organigrammeStructurel = canViewOrganigrammeStructurel %}
                    {% set organigrammeImmobilier = canViewOrganigrammeImmobilier %}
                    {% set organigrammeHierarchique = canViewOrganigrammeHierarchique %}

                    {% set canViewEncours = isAdmin or ('ROLE_ENCOURS_VIEW' in roles) %}
                    {% set canEditEncours = isAdmin or ('ROLE_ENCOURS_EDIT' in roles) %}
                    {% set canAddEncours = isAdmin or ('ROLE_ENCOURS_ADD' in roles) %}
                    {% set encoursClass = ui.accessClass(canViewEncours, canEditEncours, canAddEncours)|trim %}

                    {% set canViewSocietes = isAdmin or ('ROLE_LIST_SOCIETES_VIEW' in roles) %}
                    {% set canEditSocietes = isAdmin or ('ROLE_LIST_SOCIETES_EDIT' in roles) %}
                    {% set canAddSocietes = isAdmin or ('ROLE_LIST_SOCIETES_ADD' in roles) %}
                    {% set societesClass = ui.accessClass(canViewSocietes, canEditSocietes, canAddSocietes)|trim %}

                    {% set canViewCentres = isAdmin or ('ROLE_LIST_CENTRES_VIEW' in roles) %}
                    {% set canEditCentres = isAdmin or ('ROLE_LIST_CENTRES_EDIT' in roles) %}
                    {% set canAddCentres = isAdmin or ('ROLE_LIST_CENTRES_ADD' in roles) %}
                    {% set centresClass = ui.accessClass(canViewCentres, canEditCentres, canAddCentres)|trim %}

                    {% set canViewVoitures = isAdmin or ('ROLE_LIST_VOITURES_VIEW' in roles) %}
                    {% set canEditVoitures = isAdmin or ('ROLE_LIST_VOITURES_EDIT' in roles) %}
                    {% set canAddVoitures = isAdmin or ('ROLE_LIST_VOITURES_ADD' in roles) %}
                    {% set voituresClass = ui.accessClass(canViewVoitures, canEditVoitures, canAddVoitures)|trim %}

                    {% set canViewSalaries = isAdmin or ('ROLE_LIST_SALARIES_VIEW' in roles) %}
                    {% set canEditSalaries = isAdmin or ('ROLE_LIST_SALARIES_EDIT' in roles) %}
                    {% set canAddSalaries = isAdmin or ('ROLE_LIST_SALARIES_ADD' in roles) %}
                    {% set salariesClass = ui.accessClass(canViewSalaries, canEditSalaries, canAddSalaries)|trim %}

                    <tr>
                        <td>{{ userList.username }}</td>
                        <td>{{ userList.email }}</td>
                        <td>
                            {% if isAdmin %}
                                Administrateur
                            {% else %}
                                {% set labels = [] %}
                                {% if 'ROLE_CTS' in roles %}{% set labels = labels|merge(['CTS']) %}{% endif %}
                                {% if 'ROLE_ASTIKOTO' in roles %}{% set labels = labels|merge(['Astikoto']) %}{% endif %}
                                {{ labels is empty ? 'Utilisateur' : labels|join(' + ') }}
                            {% endif %}
                        </td>
                        <td class="{{ canEditOrganigrams ? 'increased' : 'decreased' }} centered">
                            {{ canEditOrganigrams ? '✓' : '✕' }}
                        </td>
                        <td class="{{ organigrammeStructurel ? 'increased' : 'decreased' }} centered">
                            {{ organigrammeStructurel ? '✓' : '✕' }}
                        </td>
                        <td class="{{ organigrammeImmobilier ? 'increased' : 'decreased' }} centered">
                            {{ organigrammeImmobilier ? '✓' : '✕' }}
                        </td>
                        <td class="{{ organigrammeHierarchique ? 'increased' : 'decreased' }} centered">
                            {{ organigrammeHierarchique ? '✓' : '✕' }}
                        </td>
                        <td class="{{ encoursClass }} centered hoverable">
                            &#11044
                            <div class="user-overlay">
                                <div class="user-overlay-row">
                                    Voir :
                                    <span class="{{ canViewEncours ? 'increased' : 'decreased' }}">
                                        {{ canViewEncours ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Modifier :
                                    <span class="{{ canEditEncours ? 'increased' : 'decreased' }}">
                                        {{ canEditEncours ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Ajouter :
                                    <span class="{{ canAddEncours ? 'increased' : 'decreased' }}">
                                        {{ canAddEncours ? '✓' : '✕' }}
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td class="td-centres-selectlike">
                            {% if isAdmin %}
                                Toutes
                            {% else %}
                                {# Build an optgroup-friendly structure: company -> list of centres. #}
                                {% set centresBySociete = {} %}
                                {% set societeNames = [] %}

                                {% for centre in userList.centres %}
                                    {% set societeName = centre.societe ? centre.societe.nom : '(Sans societe)' %}
                                    {% if societeName not in societeNames %}
                                        {% set societeNames = societeNames|merge([societeName]) %}
                                    {% endif %}

                                    {% set current = centresBySociete[societeName]|default([]) %}
                                    {% set centresBySociete = centresBySociete|merge({ (societeName): current|merge([centre]) }) %}
                                {% endfor %}

                                <div class="centres-selectlike">
                                    <select multiple
                                            data-centres-selectlike="1"
                                            data-centres-selectlike-readonly="1"
                                            aria-label="Centres rattachés">
                                        {% for societeName in societeNames|sort %}
                                            <optgroup label="{{ societeName }}">
                                                {% for centre in centresBySociete[societeName] %}
                                                    {% set reseau = centre.reseauNom|default('') %}
                                                    {% set ville = centre.ville|default('') %}
                                                    {% set agr = centre.agrCentre|default('') %}
                                                    {% set label = (reseau ~ ' ' ~ ville ~ (agr != '' ? ' (' ~ agr ~ ')' : ''))|trim %}
                                                    <option value="{{ centre.id }}" selected>{{ label }}</option>
                                                {% endfor %}
                                            </optgroup>
                                        {% endfor %}
                                    </select>
                                </div>
                            {% endif %}
                        </td>
                        <td class="{{ societesClass }} centered hoverable">
                            &#11044
                            <div class="user-overlay">
                                <div class="user-overlay-row">
                                    Voir :
                                    <span class="{{ canViewSocietes ? 'increased' : 'decreased' }}">
                                        {{ canViewSocietes ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Modifier :
                                    <span class="{{ canEditSocietes ? 'increased' : 'decreased' }}">
                                        {{ canEditSocietes ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Ajouter :
                                    <span class="{{ canAddSocietes ? 'increased' : 'decreased' }}">
                                        {{ canAddSocietes ? '✓' : '✕' }}
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td class="{{ centresClass }} centered hoverable">
                            &#11044
                            <div class="user-overlay">
                                <div class="user-overlay-row">
                                    Voir :
                                    <span class="{{ canViewCentres ? 'increased' : 'decreased' }}">
                                        {{ canViewCentres ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Modifier :
                                    <span class="{{ canEditCentres ? 'increased' : 'decreased' }}">
                                        {{ canEditCentres ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Ajouter :
                                    <span class="{{ canAddCentres ? 'increased' : 'decreased' }}">
                                        {{ canAddCentres ? '✓' : '✕' }}
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td class="{{ voituresClass }} centered hoverable">
                            &#11044
                            <div class="user-overlay">
                                <div class="user-overlay-row">
                                    Voir :
                                    <span class="{{ canViewVoitures ? 'increased' : 'decreased' }}">
                                        {{ canViewVoitures ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Modifier :
                                    <span class="{{ canEditVoitures ? 'increased' : 'decreased' }}">
                                        {{ canEditVoitures ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Ajouter :
                                    <span class="{{ canAddVoitures ? 'increased' : 'decreased' }}">
                                        {{ canAddVoitures ? '✓' : '✕' }}
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td class="{{ salariesClass }} centered hoverable">
                            &#11044
                            <div class="user-overlay">
                                <div class="user-overlay-row">
                                    Voir :
                                    <span class="{{ canViewSalaries ? 'increased' : 'decreased' }}">
                                        {{ canViewSalaries ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Modifier :
                                    <span class="{{ canEditSalaries ? 'increased' : 'decreased' }}">
                                        {{ canEditSalaries ? '✓' : '✕' }}
                                    </span>
                                </div>
                                <div class="user-overlay-row">
                                    Ajouter :
                                    <span class="{{ canAddSalaries ? 'increased' : 'decreased' }}">
                                        {{ canAddSalaries ? '✓' : '✕' }}
                                    </span>
                                </div>
                            </div>
                        </td>
                        <td class="table-action">
                            <a class="btn-link"
                               href="{{ path('app_users_edit', { id: userList.id }) }}">Modifier</a>
                        </td>
                        <td class="table-action">
                            {% if userList.id not in [1, 2] %}
                                <form action="{{ path('app_users_delete', { id: userList.id }) }}"
                                      method="post"
                                      data-controller="confirm-modal-trigger"
                                      data-confirm-modal-trigger-message-value=""
                                >
                                    <input type="hidden" name="_token"
                                           value="{{ csrf_token('delete-user-' ~ userList.id) }}">
                                    <button type="button" class="delete"
                                            data-action="click->confirm-modal-trigger#open">
                                        X
                                    </button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% set errorsMessages = app.flashes('error') %}
    {% if errorsMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h3>Erreurs détectées</h3>
                <ul>
                    {% for error in errorsMessages %}
                        <li>{{ error }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    {% endif %}

    {% set successMessages = app.flashes('success') %}
    {% if successMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal success-modal" data-modals-target="modal">
                <h2>Succès</h2>

                {% for message in successMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    {% set warningMessages = app.flashes('warning') %}
    {% if warningMessages is not empty %}
        <div id="modal" class="modal-overlay" data-controller="modals" data-modals-target="overlay">
            <div class="modal error-modal" data-modals-target="modal">
                <h2>Attention</h2>

                {% for message in warningMessages %}
                    <p>{{ message }}</p>
                {% endfor %}

                <button id="close-modal" data-action="click->modals#hide">OK</button>
            </div>
        </div>
    {% endif %}

    <div id="confirmModal" class="modal-overlay" data-controller="confirm-modal" data-confirm-modal-target="overlay">
        <div class="modal error-modal" data-confirm-modal-target="modal">
            <img src="{{ asset("/img/warning.png") }}" alt="attention">

            <p>Souhaitez-vous vraiment supprimer cet utilisateur ?</p>
            <p>Cette action est irréversible.</p>

            <div class="modal-buttons">
                <button type="button" class="abort-btn" data-action="click->confirm-modal#hide">Annuler</button>
                <button type="button" class="confirm-btn" data-action="click->confirm-modal#confirm">Supprimer</button>
            </div>
        </div>
    </div>
{% endblock %}
