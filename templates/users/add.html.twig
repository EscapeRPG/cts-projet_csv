{% extends 'base.html.twig' %}

{% block title %}Ajouter un utilisateur{% endblock %}

{% block body %}
    <div class="form-wrapper">
        {{ form_start(form) }}

        <div class="form-row">
            {{ form_label(form.username) }}
            {{ form_errors(form.username) }}
            {{ form_widget(form.username) }}
        </div>

        <div class="form-row">
            {{ form_label(form.email) }}
            {{ form_errors(form.email) }}
            {{ form_widget(form.email) }}
        </div>

        <div class="form-row">
            {{ form_label(form.isAdmin) }}
            {{ form_errors(form.isAdmin) }}
            {{ form_widget(form.isAdmin) }}
        </div>

        <div class="form-row">
            {{ form_label(form.entreprises) }}
            {{ form_errors(form.entreprises) }}

            <div class="form-choice-group" data-choice-group="entreprises">
                {% for choice in form.entreprises %}
                    {% set v = choice.vars.value %}
                    {% set logo = v == 'ROLE_CTS' ? asset('img/logo-cts.png') : asset('img/logo-astikoto.png') %}

                    <div class="form-choice-item">
                        {{ form_widget(choice) }}
                        <label for="{{ choice.vars.id }}">
                            <img src="{{ logo }}" alt="{{ choice.vars.label }}">
                        </label>
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(form.societe) }}
            {{ form_errors(form.societe) }}
            <div class="form-choice-group" data-choice-group="societe">
                {% for choice in form.societe %}
                    <div class="form-choice-item">
                        {{ form_widget(choice) }}
                        {{ form_label(choice) }}
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(form.centre) }}
            {{ form_errors(form.centre) }}
            <div class="form-choice-group" data-choice-group="centre">
                {% for choice in form.centre %}
                    <div class="form-choice-item">
                        {{ form_widget(choice) }}
                        {{ form_label(choice) }}
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(form.voiture) }}
            {{ form_errors(form.voiture) }}
            <div class="form-choice-group" data-choice-group="voiture">
                {% for choice in form.voiture %}
                    <div class="form-choice-item">
                        {{ form_widget(choice) }}
                        {{ form_label(choice) }}
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(form.salaries) }}
            {{ form_errors(form.salaries) }}
            <div class="form-choice-group" data-choice-group="salaries">
                {% for choice in form.salaries %}
                    <div class="form-choice-item">
                        {{ form_widget(choice) }}
                        {{ form_label(choice) }}
                    </div>
                {% endfor %}
            </div>
        </div>

        <div class="form-row">
            {{ form_label(form.centres) }}
            {{ form_errors(form.centres) }}
            <div class="centres-selectlike">
                {{ form_widget(form.centres) }}
            </div>
        </div>

        <div class="form-row">
            {{ form_errors(form) }}
        </div>

        <div class="form-row">
            {{ form_widget(form.submit) }}
        </div>

        {# CSRF token + any hidden fields #}
        {{ form_rest(form) }}
        {{ form_end(form, { render_rest: false }) }}
    </div>
{% endblock %}
